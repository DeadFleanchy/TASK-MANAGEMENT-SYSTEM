import requests

def get_website_title(url):
    """
    Attempts to retrieve the title of a website using a simple GET request.
    Note: This method is limited and may not work for all websites,
    especially those with complex JavaScript rendering.
    """
    try:
        response = requests.get(url, timeout=5)  # Added timeout
        response.raise_for_status()  # Raise HTTPError for bad responses (4xx or 5xx)
        text = response.text
        start_tag = "<title>"
        end_tag = "</title>"
        start_index = text.find(start_tag)
        end_index = text.find(end_tag)

        if start_index != -1 and end_index != -1:
            title = text[start_index + len(start_tag):end_index]
            return title.strip() #remove extra whitespace.
        else:
            return "Title not found."

    except requests.exceptions.RequestException as e:
        return f"Error: {e}"

