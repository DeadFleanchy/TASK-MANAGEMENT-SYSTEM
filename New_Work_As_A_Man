import requests
import re #Regular expressions

def get_google_search_title(search_query):
    """
    Simulates a Google search and retrieves the title of the search results page.
    This method is limited and may not perfectly replicate a real browser's behavior.
    """
    try:
        url = f"https://www.google.com/search?q={search_query.replace(' ', '+')}" #format the search query for the URL
        headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'} #add a user agent to prevent some bot detection.
        response = requests.get(url, headers=headers, timeout=10) #added headers, and timeout
        response.raise_for_status() # Raise HTTPError for bad responses (4xx or 5xx)
        text = response.text
        title_match = re.search(r'<title>(.*?)</title>', text, re.IGNORECASE) #Use regular expression to find title.
        if title_match:
            title = title_match.group(1).strip()
            return title
        else:
            return "Title not found."

    except requests.exceptions.RequestException as e:
        return f"Error: {e}"

